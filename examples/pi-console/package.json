{
  "name": "pi-console",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:runtime": "pnpm --filter @trust-substrate/pi-local-runtime build",
    "sync:data": "node ./scripts/sync-data.mjs",
    "dev": "pnpm run build:runtime && vite --host 127.0.0.1",
    "build": "pnpm run build:runtime && pnpm run sync:data && tsc -b && vite build",
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-web-ui": "0.74.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@solana/kit": "6.9.0",
    "@trust-substrate/pi-local-runtime": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.10.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11"
  }
}
