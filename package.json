{
  "name": "trust-substrate",
  "version": "0.0.0",
  "private": true,
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "pnpm test:packages && pnpm test:rust && pnpm test:verification",
    "test:packages": "npm test --prefix packages/sdk && npm test --prefix packages/indexer",
    "test:rust": "cargo test --workspace",
    "test:verification": "node --test --experimental-strip-types tests/verification/*.test.ts",
    "test:audit": "node --test --experimental-strip-types tests/audit/*.test.ts",
    "test:anchor": "anchor test",
    "test:surfpool": "./scripts/surfpool-e2e.sh",
    "lint:fix": "prettier \"**/*.{js,ts}\" -w",
    "lint": "prettier \"**/*.{js,ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1"
  },
  "devDependencies": {
    "chai": "4.3.4",
    "mocha": "9.0.3",
    "ts-mocha": "10.0.0",
    "@types/bn.js": "5.1.0",
    "@types/chai": "4.3.0",
    "@types/mocha": "9.0.0",
    "typescript": "5.7.3",
    "prettier": "2.6.2"
  }
}
