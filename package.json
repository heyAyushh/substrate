{
  "name": "trust-substrate",
  "version": "0.1.0",
  "private": true,
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "generate:clients": "pnpm exec node scripts/generate-program-clients.mjs",
    "test": "pnpm test:packages && pnpm test:rust && pnpm test:anchor && pnpm test:verification",
    "test:packages": "npm test --prefix packages/sdk && npm test --prefix packages/indexer",
    "test:rust": "cargo test --workspace --exclude trust_substrate_litesvm_tests",
    "test:verification": "node --test --experimental-strip-types tests/verification/*.test.ts",
    "test:litesvm": "anchor test --skip-lint --skip-local-validator --skip-deploy",
    "test:anchor": "pnpm test:litesvm",
    "test:surfpool": "./scripts/surfpool-e2e.sh",
    "lint:fix": "prettier \"**/*.{js,ts}\" -w",
    "lint": "prettier \"**/*.{js,ts}\" --check"
  },
  "dependencies": {
    "@anchor-lang/core": "1.0.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "1.4.0",
    "@codama/renderers-js": "2.1.0",
    "@types/bn.js": "5.1.0",
    "@types/chai": "4.3.0",
    "@types/mocha": "9.0.0",
    "@trust-substrate/indexer": "workspace:*",
    "@trust-substrate/sdk": "workspace:*",
    "chai": "4.3.4",
    "codama": "1.5.1",
    "mocha": "9.0.3",
    "prettier": "2.6.2",
    "ts-mocha": "10.0.0",
    "typescript": "5.7.3"
  }
}
