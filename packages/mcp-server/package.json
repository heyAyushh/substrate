{
  "name": "@trust-substrate/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "trust-substrate-mcp-server": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./snapshot-tools": {
      "types": "./dist/snapshot-tools.d.ts",
      "import": "./dist/snapshot-tools.js",
      "default": "./dist/snapshot-tools.js"
    }
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "pnpm --filter @trust-substrate/indexer build && tsc -p tsconfig.build.json",
    "test": "pnpm run build && tsc -p tsconfig.test.json && node --test dist-tests/tests/mcp-server/*.test.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true }); require('node:fs').rmSync('dist-tests', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@trust-substrate/indexer": "workspace:*",
    "zod": "3.25.76"
  }
}
