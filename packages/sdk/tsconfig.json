{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist",
    "rootDir": "../..",
    "lib": ["ES2022"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "../../tests/sdk/**/*.ts"
  ]
}
