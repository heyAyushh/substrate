// Anchor-derived QEDGen protocol spec.
//
// Scope: stake account lifecycle, unstake cooldowns, and one-time slash markers.
// Token stake handlers are modeled with the same stake amount fields plus
// token-specific PDA coverage.

spec AgentStake

program_id "47FjPydQsbVfMHAb1apZTRrY1pWq2JGyRzgenUaos9on"

const MAX_U64 = 18_446_744_073_709_551_615

type Error
  | MathOverflow

type AgentIdentity
  | Uninitialized
  | Active of {
      authority            : Pubkey,
      agent_id             : U64,
      policy_root          : U64,
      history_root         : U64,
      tier                 : U8,
      open_task_count      : U32,
      open_challenge_count : U32,
      active_stake         : Bool,
      active_stake_count   : U32,
      bump                 : U8
    }
  | Closed

type DisputeVerdict
  | Uninitialized
  | Active of {
      dispute_receipt  : Pubkey,
      target_identity  : Pubkey,
      outcome          : U8,
      slash_amount     : U64,
      adjudicator      : Pubkey,
      created_at_slot  : U64,
      bump             : U8,
      class            : U8,
      stale_after_slot : U64
    }
  | Closed

type ReceiptRecord
  | Uninitialized
  | Active of {
      identity          : Pubkey,
      task              : Pubkey,
      receipt_id        : U64,
      actor             : Pubkey,
      kind              : U8,
      sequence          : U64,
      domain            : U64,
      previous_receipt  : U64,
      payload_hash      : U64,
      via_delegation    : Pubkey,
      auditor_identity  : Pubkey,
      target_receipt    : Pubkey,
      challenge_receipt : Pubkey,
      deadline_slot     : U64,
      round             : U16,
      bump              : U8
    }
  | Closed

type SlashMarker
  | Uninitialized
  | Active of {
      stake           : Pubkey,
      dispute_receipt : Pubkey,
      verdict         : Pubkey,
      amount          : U64,
      bump            : U8
    }
  | Closed

type StakeAccount
  | Uninitialized
  | Active of {
      identity               : Pubkey,
      owner                  : Pubkey,
      slash_authority        : Pubkey,
      trust_mode             : U8,
      amount                 : U64,
      pending_unstake_amount : U64,
      unstake_unlocks_at     : U64,
      slashed_total          : U64,
      bump                   : U8
    }
  | Closed

type StakeDeposited
  | Uninitialized
  | Active of {
      identity  : Pubkey,
      authority : Pubkey,
      amount    : U64,
      slot      : U64
    }
  | Closed

type StakeInitialized
  | Uninitialized
  | Active of {
      identity        : Pubkey,
      authority       : Pubkey,
      slash_authority : Pubkey,
      trust_mode      : U8,
      slot            : U64
    }
  | Closed

type StakeSlashedByAuthority
  | Uninitialized
  | Active of {
      identity        : Pubkey,
      slash_authority : Pubkey,
      dispute_receipt : Pubkey,
      amount          : U64,
      trust_mode      : U8,
      slot            : U64
    }
  | Closed

type StakeSlashedWithVerdict
  | Uninitialized
  | Active of {
      identity        : Pubkey,
      adjudicator     : Pubkey,
      dispute_receipt : Pubkey,
      verdict         : Pubkey,
      amount          : U64,
      trust_mode      : U8,
      slot            : U64
    }
  | Closed

type StakeUnstakeFinalized
  | Uninitialized
  | Active of {
      identity  : Pubkey,
      authority : Pubkey,
      amount    : U64,
      slot      : U64
    }
  | Closed

type StakeUnstakeRequested
  | Uninitialized
  | Active of {
      identity               : Pubkey,
      authority              : Pubkey,
      amount                 : U64,
      pending_unstake_amount : U64,
      unlocks_at_slot        : U64,
      slot                   : U64
    }
  | Closed

type TokenStakeAccount
  | Uninitialized
  | Active of {
      identity               : Pubkey,
      owner                  : Pubkey,
      slash_authority        : Pubkey,
      trust_mode             : U8,
      scope                  : Pubkey,
      mint                   : Pubkey,
      spl_program            : Pubkey,
      vault                  : Pubkey,
      amount                 : U64,
      pending_unstake_amount : U64,
      unstake_unlocks_at     : U64,
      slashed_total          : U64,
      bump                   : U8,
      vault_bump             : U8
    }
  | Closed

type TreasuryVault
  | Uninitialized
  | Active of {
      bump : U8
    }
  | Closed

pda stake ["stake", identity]
pda token_stake ["token_stake", identity, scope, mint]
pda token_stake_vault ["token_stake_vault", token_stake]
pda slash_marker ["slash_marker", stake, dispute_receipt]
pda verdict ["verdict", dispute_receipt]
pda treasury_vault ["treasury"]
pda token_treasury_vault ["token_treasury_vault", mint]

handler finalize_unstake : State.Active -> State.Active {
  auth owner
  requires pending_unstake_amount > 0
  requires amount >= pending_unstake_amount
  effect {
    amount -= pending_unstake_amount
    pending_unstake_amount := 0
    unstake_unlocks_at := 0
  }
  accounts {
    owner : signer, writable
    identity : writable
    stake : writable, pda [stake]
    identity_registry_program : readonly
  }
}

handler initialize_stake (slash_authority : Pubkey) (trust_mode : U8) : State.Uninitialized -> State.Active {
  auth owner
  effect {
    owner := owner
    slash_authority := slash_authority
    trust_mode := trust_mode
    amount := 0
    pending_unstake_amount := 0
    slashed_total := 0
  }
  accounts {
    owner : signer, writable
    identity : readonly
    stake : writable, pda [stake]
    system_program : program
  }
}

handler request_unstake (unstake_amount : U64) : State.Active -> State.Active {
  auth owner
  requires unstake_amount > 0
  requires amount >= unstake_amount
  effect {
    pending_unstake_amount := unstake_amount
    unstake_unlocks_at +=! 1
  }
  accounts {
    owner : signer
    stake : writable, pda [stake]
  }
}

handler slash_with_authority (slash_amount : U64) : State.Active -> State.Active {
  auth slash_authority
  requires slash_amount > 0
  requires amount >= slash_amount
  effect {
    amount -= slash_amount
    slashed_total +=! slash_amount
    pending_unstake_amount := 0
    unstake_unlocks_at := 0
  }
  accounts {
    slash_authority : signer, writable
    stake : writable, pda [stake]
    dispute_receipt : readonly
    slash_marker : writable, pda [slash_marker]
    treasury_vault : writable, pda [treasury_vault]
    system_program : program
  }
}

handler slash_with_verdict : State.Active -> State.Active {
  auth adjudicator
  requires amount > 0
  effect {
    slashed_total +=! amount
    amount := 0
    pending_unstake_amount := 0
    unstake_unlocks_at := 0
  }
  accounts {
    adjudicator : signer, writable
    stake : writable, pda [stake]
    dispute_receipt : readonly
    verdict : pda [verdict]
    slash_marker : writable, pda [slash_marker]
    treasury_vault : writable, pda [treasury_vault]
    system_program : program
  }
}

handler stake (deposit_amount : U64) : State.Active -> State.Active {
  auth owner
  requires deposit_amount > 0
  requires amount <= MAX_U64 - deposit_amount
  effect {
    amount += deposit_amount
  }
  accounts {
    owner : signer, writable
    identity : writable
    stake : writable, pda [stake]
    identity_registry_program : readonly
    system_program : program
  }
}

handler initialize_token_stake (scope : Pubkey) (slash_authority : Pubkey) (trust_mode : U8) : State.Uninitialized -> State.Active {
  auth owner
  effect {
    owner := owner
    slash_authority := slash_authority
    trust_mode := trust_mode
    scope := scope
    amount := 0
    pending_unstake_amount := 0
    slashed_total := 0
  }
  accounts {
    owner : signer, writable
    identity : readonly
    mint : readonly
    token_stake : writable, pda [token_stake]
    vault : writable, pda [token_stake_vault]
    spl_token_program : readonly
    system_program : program
  }
}

handler initialize_token_treasury_vault : State.Uninitialized -> State.Active {
  permissionless
  accounts {
    payer : signer, writable
    treasury_vault : pda [treasury_vault]
    mint : readonly
    treasury_token_vault : writable, pda [token_treasury_vault]
    spl_token_program : readonly
    system_program : program
  }
}

handler stake_token (deposit_amount : U64) : State.Active -> State.Active {
  auth owner
  requires deposit_amount > 0
  requires amount <= MAX_U64 - deposit_amount
  effect {
    amount += deposit_amount
  }
  transfers {
    from owner_token_account to vault amount deposit_amount authority owner
  }
  accounts {
    owner : signer, writable
    identity : writable
    token_stake : writable, pda [token_stake]
    mint : readonly
    owner_token_account : writable
    vault : writable, pda [token_stake_vault]
    token_program : program
    identity_registry_program : readonly
  }
}

handler request_unstake_token (unstake_amount : U64) : State.Active -> State.Active {
  auth owner
  requires unstake_amount > 0
  requires amount >= unstake_amount
  effect {
    pending_unstake_amount := unstake_amount
    unstake_unlocks_at +=! 1
  }
  accounts {
    owner : signer
    token_stake : writable, pda [token_stake]
  }
}

handler finalize_unstake_token : State.Active -> State.Active {
  auth owner
  requires pending_unstake_amount > 0
  requires amount >= pending_unstake_amount
  effect {
    amount -= pending_unstake_amount
    pending_unstake_amount := 0
    unstake_unlocks_at := 0
  }
  transfers {
    from vault to owner_token_account amount pending_unstake_amount authority token_stake
  }
  accounts {
    owner : signer, writable
    token_stake : writable, pda [token_stake]
    identity : writable
    mint : readonly
    owner_token_account : writable
    vault : writable, pda [token_stake_vault]
    token_program : program
    identity_registry_program : readonly
  }
}

handler slash_token_with_authority (slash_amount : U64) : State.Active -> State.Active {
  auth slash_authority
  requires slash_amount > 0
  requires amount >= slash_amount
  effect {
    amount -= slash_amount
    slashed_total +=! slash_amount
    pending_unstake_amount := 0
    unstake_unlocks_at := 0
  }
  transfers {
    from vault to treasury_token_vault amount slash_amount authority token_stake
  }
  accounts {
    slash_authority : signer, writable
    token_stake : writable, pda [token_stake]
    dispute_receipt : readonly
    slash_marker : writable, pda [slash_marker]
    mint : readonly
    vault : writable
    treasury_token_vault : writable, pda [token_treasury_vault]
    token_program : program
    system_program : program
  }
}

handler slash_token_with_verdict : State.Active -> State.Active {
  auth adjudicator
  requires amount > 0
  effect {
    slashed_total +=! amount
    amount := 0
    pending_unstake_amount := 0
    unstake_unlocks_at := 0
  }
  transfers {
    from vault to treasury_token_vault amount amount authority token_stake
  }
  accounts {
    adjudicator : signer, writable
    token_stake : writable, pda [token_stake]
    dispute_receipt : readonly
    verdict : pda [verdict]
    slash_marker : writable, pda [slash_marker]
    mint : readonly
    vault : writable
    treasury_token_vault : writable, pda [token_treasury_vault]
    token_program : program
    system_program : program
  }
}

property pending_unstake_bounded :
  amount >= pending_unstake_amount
  preserved_by all

invariant slash_marker_unique :
  forall left right : SlashMarker.Active,
    (left.stake == right.stake and left.dispute_receipt == right.dispute_receipt) implies left == right
